    #  UI.user_error!("APK did not install successfully. \n\nError: #{result}") unless(result.eql? 'Success')
    #end
  end
end

def run_android_tests(test_class, package_name, addition_ops = nil)
  class_param =  "-Pandroid.testInstrumentationRunnerArguments.class=#{test_class}"
  package_param = "-Pandroid.testInstrumentationRunnerArguments.packageName=#{package_name}"
  password_param = "-Pandroid.testInstrumentationRunnerArguments.password=#{$password}"
  addition_ops = '' unless addition_ops

  puts "test_class: #{test_class}"
  puts "package_name: #{package_name}"
  

  Dir.chdir('./Android/') do
    UI.header 'Run Tests Locally'
    
    begin
       result = system("./gradlew #{class_param} #{package_param} #{password_param} #{addition_ops} connectedAndroidTest")
    ensure
      system("adb uninstall #{package_name}")
      UI.user_error!('Tests failed.') unless(result)
    end
  end
end

def run_android_tests_firebase(test_class, package_name, app_path, addition_ops = nil)
  puts "app path: #{app_path}"

  Dir.chdir('./Android/') do
    UI.header 'Run Tests'

    system("./gradlew app:assembleAndroidTest")
    system("gcloud firebase test android run \
      --project mobile-apps-firebase-test \
      --type instrumentation \
      --app #{app_path}/build/outputs/apk/debug/app-debug.apk \
      --test app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk \
      --device model=NexusLowRes,version=27,locale=en,orientation=portrait  \
      --results-dir=UITest-Local-${CIRCLE_BUILD_NUM}  \
      --results-history-name=UITest-Local  \
      --timeout 10m  \
      -—environment-variables class=#{test_class},packageName=#{packageName},password=#{password}")
  end
end

# This is only setup to run against native java app
def enable_android_sp(app_path)
  app_name = 'native_java'
  idp_commnet = '// SmartSyncSDKManager.getInstance().setIDPAppURIScheme(idpAppURIScheme);'
  idp_code = 'SmartSyncSDKManager.getInstance().setIDPAppURIScheme("com.salesforce.native_kotlin://authenticator");'

  source_extention = (app_name.eql? 'native_kotlin') ? 'kt' : 'java'
  source_path = app_path + "app/src/com/salesforce/#{app_name}/MainApplication.#{source_extention}"
  modify_source(source_path, idp_commnet, idp_code)
  change_connected_app(app_path, app_name, $sp_consumer_key, $sp_redirect_uri)

  Dir.chdir(app_path) do
    UI.important 'Building App after Source Modifications'
    `./gradlew assembleDebug`
  end
end

#
# iOS Helper Functions
#
def base_ios_test_setup(options)
  system('rm -rf ../../tmp*')
  system('rm -rf ../../test_output/')

  $password = get_password
  run_type = options[:type]
  UI.user_error!('Please specify run type.') unless(run_type)
  sfdx = options[:sfdx]
  skipRemoveApp = options[:skipRemoveApp]
  device = options[:device]
  ios = options[:ios]
  xcode_path = '/Applications/Xcode.app/Contents/Developer/Applications/Simulator.app'

  if device
    device.gsub!(' ', '-')
  else
    device = 'iPhone-XR'
  end

  if ios
    ios.slice!(0, 3)
    ios.gsub!('.', '-')
  else
    ios = '12-2'
  end

  puts "device: #{device}, ios: #{ios}" 
  system("xcrun simctl delete #{$sim_name}") or puts "No old device to delete"
  sim_id = `xcrun simctl create #{$sim_name} com.apple.CoreSimulator.SimDeviceType.#{device} com.apple.CoreSimulator.SimRuntime.iOS-#{ios}`.delete("\n")

  Dir.chdir('../../') do
    generate_app('ios', run_type, nil, sfdx)
    app_name = "App_#{run_type}_ios"
    path = Dir.glob("tmp*").first.concat("/#{app_name}/")

    case run_type
      when 'native'
        bundle_name = 'com.salesforce.App-native-ios'
      when 'native_swift'
        bundle_name = 'com.salesforce.App-native-swift-ios'
      when 'react_native'
        path.concat('ios/')
        bundle_name = 'com.salesforce.App-react-native-ios'

        if run_type == 'react_native'
          Dir.chdir(path) do
            system('npm start&')
          end
        end
      else
        path.concat('platforms/ios/')
        bundle_name = 'com.salesforce.'.concat(run_type)
    end

    # Start Simulator
    system("xcrun simctl boot #{sim_id}")
    system("open #{xcode_path} --args -CurrentDeviceUDID #{sim_id}")

    return '../../' + path, bundle_name
  end
end

def install_ios_app(app_path, release = nil)
  app_name = app_path.split('/').grep(/ios/).first
  Dir.chdir(app_path) do
    UI.important 'Build for Simulator'
    silence_output { system("xcodebuild build -scheme #{app_name} -workspace #{app_name}.xcworkspace -sdk iphonesimulator -derivedDataPath ./DerivedData") }

    UI.important 'Installing App on Simulator'
    system("xcrun simctl install booted ./DerivedData/Build/Products/Debug-iphonesimulator/#{app_name}.app")
  end
end

def run_ios_tests(bundle_name, test_scheme, xcargs = nil)
  xcargs_string = ''
  xcargs.each { |arg| xcargs_string += "'#{arg}' " } unless xcargs.nil?

  Dir.chdir('../../iOS/') do
    destination = "#{$sim_name} (" + `instruments -s devices | grep #{$sim_name} | awk -F"[()]" '{print $2}'`.delete("\n") + ")"
    begin
      scan(
        project: 'iOS/SalesforceMobileSDK-UITest.xcodeproj',
        scheme: test_scheme,
        device: destination,
        output_directory: 'test_output',
        clean: true,
        xcargs: "'TEST_APP_BUNDLE=#{bundle_name}' 'PASSWORD=#{$password}' #{xcargs_string}"
      )
    ensure
      system("xcrun simctl shutdown #{$sim_name}")
    end
  end
end

def enable_ios_sp(app_path)
  app_name = app_path.split('/').last
  enable_idp_comment = '//Uncomment the following line in order to enable/force the use of advanced authentication flow.'
  enable_idp = "[SalesforceSDKManager sharedManager].idpAppURIScheme = @\"#{$idp_redirect_uri.split(':').first}\";"
  handle_response = 'return [[SFUserAccountManager sharedInstance] handleAdvancedAuthenticationResponse:url options:options];'

  sourcePath = app_path + app_name + '/AppDelegate.m'
  modify_source(sourcePath, enable_idp_comment, enable_idp)
  modify_source(sourcePath, $comment + handle_response, handle_response)
  change_connected_app(app_path, app_name, $sp_consumer_key, $sp_redirect_uri)

  plist_path = File.expand_path(app_path + app_name + '/Info.plist')
  value = [{'CFBundleURLSchemes' => [$sp_redirect_uri.split(':').first]}]
  set_info_plist_value(path: plist_path, key: 'CFBundleURLTypes', value: value)
end

def enable_ios_logout(app_path)
  logout_code = 'NSArray *args = [[NSProcessInfo processInfo] arguments]; if (args != nil) { for (NSString *arg in args) { if ([arg  isEqual: @"logout"]) { [[SFUserAccountManager sharedInstance] logout]; } } }'
  comment = '//Uncomment the code below to see how you can customize the color, textcolor, font and   fontsize of the navigation bar'

  app_name = app_path.split('/').last
  modify_source( app_path + app_name + '/AppDelegate.m', comment, logout_code)
end