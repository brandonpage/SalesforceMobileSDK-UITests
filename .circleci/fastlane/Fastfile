lane :ios_idp do |options|
  path, bundle_name = base_ios_test_setup(options)

  # Setup SP App
  enable_ios_sp(path)
  enable_ios_logout(path)
  install_ios_app(path)

  # Setup IDP App
  template_url = 'https://github.com/forcedotcom/SalesforceMobileSDK-Templates/iOSIDPTemplate'
  Dir.chdir('../../') do
    generate_app('ios', nil,  template_url)
    idp_path = Dir.glob("tmp*").sort.last.concat('/App_native_swift_ios/')
    change_connected_app(idp_path, 'App_native_swift_ios', $idp_consumer_key, $idp_redirect_uri)

    project_name = idp_path.split('/').last
    plist_path = File.expand_path(idp_path + '/' + project_name + '/Info.plist')
    value = [{'CFBundleURLSchemes' => [$idp_redirect_uri.split(':').first]}]
    set_info_plist_value(path: plist_path, key: 'CFBundleURLTypes', value: value)

    project_path = File.expand_path(idp_path + project_name + '.xcodeproj')
    update_app_identifier(xcodeproj: project_path, plist_path: plist_path, app_identifier: 'com.salesforce.idp')
    install_ios_app(idp_path)
  end

  run_ios_tests(bundle_name, 'IDPTests', nil)
end

